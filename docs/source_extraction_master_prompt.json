    ]
  },
  "final_response_format": {
    "instruction": "Return the report in this exact section order. If data is too large, provide the first section and say which section should be requested next.",
    "sections": [
      "1. Batch Executive Summary",
      "2. Source Inventory",
      "3. Comprehensive Timeline CSV Table",
      "4. Month-by-Month Forward Sequence",
      "5. Steven Statement Bank",
      "6. Contradiction and Gap Ledger",
      "7. Location / Map Extraction",
      "8. People / Agency / System Contact Ledger",
      "9. Body Evidence Ledger",
      "10. Chapter Candidates",
      "11. Visual Novel Node Candidates",
      "12. Public-Facing Safety Review",
      "13. Items Requiring Steven Approval",
      "14. Copy/Paste CSV Blocks"
    ]
  },
  "quality_control": {
    "before_answering_checklist": [
      "Did I use only uploaded sources?",
      "Did I preserve exact Steven wording where possible?",
      "Did I mark unknowns instead of inventing?",
      "Did I mark verification needs?",
      "Did I avoid legal/medical conclusions?",
      "Did I keep contradictions instead of smoothing them?",
      "Did every extracted item have a source anchor?",
      "Did I keep June 2025 as the forward-moving narrative start?"
    ],
    "failure_mode_instruction": "If you cannot complete all tasks due to context limits, complete source inventory and comprehensive timeline first, then ask for permission to continue with statement bank, contradictions, locations, and chapter candidates."
  }
}